#include <iostream>
#include <vector>
#include <queue>
using namespace std;

int main() {
    int n;
    cin >> n;

    vector<vector<int>> adj(n);

    for(int i = 0; i < n; i++) {
        int k;
        cin >> k;
        for(int j = 0; j < k; j++) {
            int v;
            cin >> v;
            adj[i].push_back(v);
        }
    }

    int s;
    cin >> s;

    vector<bool> vis(n, false);
    queue<int> q;

    q.push(s);
    vis[s] = true;

    while(!q.empty()) {
        int node = q.front();
        q.pop();

        cout << node << " ";

        for(int v : adj[node]) {
            if(!vis[v]) {
                vis[v] = true;
                q.push(v);
            }
        }
    }

    return 0;
}
