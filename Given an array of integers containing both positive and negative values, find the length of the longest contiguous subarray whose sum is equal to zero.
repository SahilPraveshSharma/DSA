#include <stdio.h>

#define MAX 1000

int longestZeroSumSubarray(int arr[], int n) {
    int prefixSum[MAX];
    int index[MAX];
    int size = 0;

    int sum = 0, maxLen = 0;

    for (int i = 0; i < n; i++) {
        sum += arr[i];

        if (sum == 0)
            maxLen = i + 1;

        int found = 0;
        for (int j = 0; j < size; j++) {
            if (prefixSum[j] == sum) {
                if (i - index[j] > maxLen)
                    maxLen = i - index[j];
                found = 1;
                break;
            }
        }

        if (!found) {
            prefixSum[size] = sum;
            index[size] = i;
            size++;
        }
    }

    return maxLen;
}

int main() {
    int arr[] = {15, -2, 2, -8, 1, 7, 10, 23};
    int n = sizeof(arr) / sizeof(arr[0]);

    printf("%d\n", longestZeroSumSubarray(arr, n));
    return 0;
}
