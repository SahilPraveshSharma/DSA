#include <iostream>
#include <vector>
using namespace std;

void dfs(int node, vector<vector<int>> &adj, vector<bool> &vis) {
    vis[node] = true;
    cout << node << " ";

    for(int v : adj[node]) {
        if(!vis[v]) {
            dfs(v, adj, vis);
        }
    }
}

int main() {
    int n;
    cin >> n;

    vector<vector<int>> adj(n);

    for(int i = 0; i < n; i++) {
        int k;
        cin >> k;
        for(int j = 0; j < k; j++) {
            int v;
            cin >> v;
            adj[i].push_back(v);
        }
    }

    int s;
    cin >> s;

    vector<bool> vis(n, false);

    dfs(s, adj, vis);

    return 0;
}
