#include <iostream>
using namespace std;

struct Node {
    int coeff;
    int exp;
    Node* next;
};

int main() {
    int n;
    cin >> n;

    Node* head = NULL;
    Node* temp = NULL;

    for(int i = 0; i < n; i++) {
        int c, e;
        cin >> c >> e;

        Node* newNode = new Node();
        newNode->coeff = c;
        newNode->exp = e;
        newNode->next = NULL;

        if(head == NULL) {
            head = newNode;
            temp = head;
        } else {
            temp->next = newNode;
            temp = newNode;
        }
    }

    Node* curr = head;

    while(curr != NULL) {
        if(curr->exp == 0)
            cout << curr->coeff;
        else if(curr->exp == 1)
            cout << curr->coeff << "x";
        else
            cout << curr->coeff << "x^" << curr->exp;

        if(curr->next != NULL)
            cout << " + ";

        curr = curr->next;
    }

    return 0;
}
