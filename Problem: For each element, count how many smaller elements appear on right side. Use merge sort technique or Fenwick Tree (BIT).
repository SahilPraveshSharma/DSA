#include <stdio.h>
#include <stdlib.h>

typedef struct {
    int val;
    int idx;
} Pair;

int *tempCount;

void merge(Pair arr[], int left, int mid, int right, Pair temp[]) {
    int i = left, j = mid + 1, k = left;
    int rightCount = 0;

    while(i <= mid && j <= right) {
        if(arr[i].val <= arr[j].val) {
            tempCount[arr[i].idx] += rightCount;
            temp[k++] = arr[i++];
        } else {
            rightCount++;
            temp[k++] = arr[j++];
        }
    }

    while(i <= mid) {
        tempCount[arr[i].idx] += rightCount;
        temp[k++] = arr[i++];
    }

    while(j <= right) {
        temp[k++] = arr[j++];
    }

    for(i = left; i <= right; i++) {
        arr[i] = temp[i];
    }
}

void mergeSort(Pair arr[], int left, int right, Pair temp[]) {
    if(left >= right) return;

    int mid = left + (right - left) / 2;

    mergeSort(arr, left, mid, temp);
    mergeSort(arr, mid + 1, right, temp);
    merge(arr, left, mid, right, temp);
}

int main() {
    int n;
    scanf("%d", &n);

    Pair arr[n], temp[n];
    tempCount = (int*)calloc(n, sizeof(int));

    for(int i = 0; i < n; i++) {
        scanf("%d", &arr[i].val);
        arr[i].idx = i;
    }

    mergeSort(arr, 0, n - 1, temp);

    for(int i = 0; i < n; i++) {
        printf("%d ", tempCount[i]);
    }

    free(tempCount);
    return 0;
}
