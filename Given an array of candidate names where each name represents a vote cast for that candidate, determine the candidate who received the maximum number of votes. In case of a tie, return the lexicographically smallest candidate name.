#include <stdio.h>
#include <string.h>

int main() {
    int n;
    scanf("%d", &n);

    char names[1000][101];
    int count[1000] = {0};
    int unique = 0;

    for (int i = 0; i < n; i++) {
        char temp[101];
        scanf("%s", temp);

        int found = -1;
        for (int j = 0; j < unique; j++) {
            if (strcmp(names[j], temp) == 0) {
                found = j;
                break;
            }
        }

        if (found != -1) {
            count[found]++;
        } else {
            strcpy(names[unique], temp);
            count[unique] = 1;
            unique++;
        }
    }

    int max_votes = 0;
    char winner[101] = "";

    for (int i = 0; i < unique; i++) {
        if (count[i] > max_votes) {
            max_votes = count[i];
            strcpy(winner, names[i]);
        } else if (count[i] == max_votes) {
            if (strcmp(names[i], winner) < 0) {
                strcpy(winner, names[i]);
            }
        }
    }

    printf("%s %d\n", winner, max_votes);

    return 0;
}
