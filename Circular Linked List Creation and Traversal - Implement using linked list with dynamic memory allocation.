#include <iostream>
using namespace std;

struct Node {
    int data;
    Node* next;
};

int main() {
    int n;
    cin >> n;

    if (n <= 0) return 0;

    Node* head = NULL;
    Node* temp = NULL;
    Node* newNode = NULL;

    for (int i = 0; i < n; i++) {
        int x;
        cin >> x;

        newNode = new Node();
        newNode->data = x;
        newNode->next = NULL;

        if (head == NULL) {
            head = newNode;
            temp = head;
        } else {
            temp->next = newNode;
            temp = newNode;
        }
    }

    temp->next = head;

    Node* curr = head;
    if (curr != NULL) {
        do {
            cout << curr->data << " ";
            curr = curr->next;
        } while (curr != head);
    }

    return 0;
}
