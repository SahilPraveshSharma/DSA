#include <stdio.h>

int max(int a, int b) {
    return (a > b) ? a : b;
}

int isPossible(int arr[], int n, int m, int limit) {
    int students = 1;
    int pages = 0;

    for(int i = 0; i < n; i++) {
        if(arr[i] > limit)
            return 0;

        if(pages + arr[i] > limit) {
            students++;
            pages = arr[i];
            if(students > m)
                return 0;
        } else {
            pages += arr[i];
        }
    }
    return 1;
}

int main() {
    int n, m;
    scanf("%d %d", &n, &m);

    int arr[n];
    int sum = 0, mx = 0;

    for(int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
        sum += arr[i];
        mx = max(mx, arr[i]);
    }

    int low = mx, high = sum, ans = sum;

    while(low <= high) {
        int mid = low + (high - low) / 2;

        if(isPossible(arr, n, m, mid)) {
            ans = mid;
            high = mid - 1;
        } else {
            low = mid + 1;
        }
    }

    printf("%d", ans);
    return 0;
}
