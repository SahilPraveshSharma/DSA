#include <stdio.h>
#include <stdlib.h>
#include <ctype.h>

struct Node {
    int data;
    struct Node* next;
};

struct Node* top = NULL;

void push(int value) {
    struct Node* newNode = (struct Node*)malloc(sizeof(struct Node));
    newNode->data = value;
    newNode->next = top;
    top = newNode;
}

int pop() {
    if (top == NULL) {
        printf("Stack Underflow\n");
        return -1;
    }
    
    struct Node* temp = top;
    int value = temp->data;
    top = top->next;
    free(temp);
    
    return value;
}

int evaluatePostfix(char exp[]) {
    int i = 0;
    char ch;
    
    while ((ch = exp[i]) != '\0') {
        
        if (isdigit(ch)) {
            push(ch - '0');
        }
        
        else {
            int val2 = pop();
            int val1 = pop();
            
            switch (ch) {
                case '+': push(val1 + val2); break;
                case '-': push(val1 - val2); break;
                case '*': push(val1 * val2); break;
                case '/': push(val1 / val2); break;
            }
        }
        
        i++;
    }
    
    return pop();
}

int main() {
    char exp[100];
    
    printf("Enter postfix expression: ");
    scanf("%s", exp);
    
    int result = evaluatePostfix(exp);
    
    printf("Result = %d\n", result);
    
    return 0;
}
